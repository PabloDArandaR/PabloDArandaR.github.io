---
import Layout from '../../layouts/ListPage.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('series')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
    title="Series"
    description="In-depth multi-part explorations of topics in robotics, mathematics, and engineering."
    posts={posts}
    startHref="series"
/>
