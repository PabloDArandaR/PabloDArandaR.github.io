---
import Layout from '../../layouts/ListPage.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
    title="Blog"
    description="Thoughts, tutorials, and notes on robotics, engineering, and whatever else ends up on the page."
    posts={posts}
    startHref="blog"
/>
