---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

interface Props {
    title: string;
    description: string;
    posts: CollectionEntry<'blog' | 'series'>[];
    startHref: string;
}

const { title, description, posts, startHref } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
    </head>
    <body>
        <script is:inline>
            (function () {
                const saved = localStorage.getItem('theme') || 'dark';
                document.documentElement.setAttribute('data-theme', saved);
            })();
        </script>
        <Header />
        <main>
            <section class="list-header">
                <h1>{title}</h1>
                <p class="subtitle">{description}</p>
            </section>

            {posts.length === 0 ? (
                <p class="empty-state">No posts yet — check back soon.</p>
            ) : (
                <ul class="post-list">
                    {posts.map((post) => (
                        <li class="post-item">
                            <a href={`/${startHref}/${post.slug}/`}>
                                {post.data.heroImage && (
                                    <div class="post-image">
                                        <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                                    </div>
                                )}
                                <div class="post-meta">
                                    <span class="post-date">
                                        <FormattedDate date={post.data.pubDate} />
                                    </span>
                                    <h2 class="post-title">{post.data.title}</h2>
                                    {post.data.description && (
                                        <p class="post-desc">{post.data.description}</p>
                                    )}
                                </div>
                            </a>
                        </li>
                    ))}
                </ul>
            )}
        </main>
        <Footer />
    </body>
</html>

<style>
    .list-header {
        margin-bottom: 3em;
        border-bottom: 1px solid var(--card-border);
        padding-bottom: 1.5em;
    }
    .list-header h1 {
        color: var(--color-strong);
        margin-bottom: 0.25em;
    }
    .subtitle {
        color: var(--content-muted);
        font-size: 1em;
        margin: 0;
    }

    .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 1.5em;
    }

    .post-item a {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1.25em;
        padding: 1.25em;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 10px;
        color: var(--content-text);
        text-decoration: none;
        transition: border-color 0.2s, transform 0.2s;
    }
    .post-item a:hover {
        border-color: var(--color-strong);
        transform: translateY(-2px);
    }
    .post-image {
        width: 120px;
        flex-shrink: 0;
    }
    .post-image img {
        width: 120px;
        height: 80px;
        object-fit: cover;
        border-radius: 6px;
    }
    .post-meta {
        display: flex;
        flex-direction: column;
        gap: 0.3em;
    }
    .post-date {
        font-size: 0.8em;
        color: var(--content-muted);
    }
    .post-title {
        font-size: 1.25em;
        margin: 0;
        color: var(--content-text);
    }
    .post-desc {
        font-size: 0.9em;
        color: var(--content-muted);
        margin: 0;
        line-height: 1.5;
    }

    .empty-state {
        text-align: center;
        color: var(--content-muted);
        font-style: italic;
        padding: 3em 0;
    }

    @media (max-width: 720px) {
        .post-item a {
            grid-template-columns: 1fr;
        }
        .post-image { width: 100%; }
        .post-image img { width: 100%; height: 160px; }
    }
</style>
