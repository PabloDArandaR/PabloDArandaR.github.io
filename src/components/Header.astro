---
import HeaderLink from './HeaderLink.astro';
import SocialLinks from './SocialLinks.astro';
import { SITE_TITLE } from '../consts';
---

<header>
    <nav>
        <!-- Site title / logo -->
        <div class="site-brand">
            <a href="/" class="brand-link">
                <span class="brand-icon" aria-hidden="true">⬡</span>
                <span class="brand-name">{SITE_TITLE}</span>
            </a>
        </div>

        <!-- Nav links -->
        <div class="nav-links">
        </div>

        <!-- Social icons + theme toggle -->
        <div class="right-cluster">
            <div class="social-links">
                <SocialLinks size={20} />
            </div>

            <!-- Theme toggle -->
            <button class="theme-toggle" id="theme-toggle" aria-label="Toggle color theme" title="Toggle light/dark">
                <span class="icon-dark" aria-hidden="true">
                    <!-- Moon -->
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                </span>
                <span class="icon-light" aria-hidden="true">
                    <!-- Sun -->
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="5"/>
                        <line x1="12" y1="1" x2="12" y2="3"/>
                        <line x1="12" y1="21" x2="12" y2="23"/>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                        <line x1="1" y1="12" x2="3" y2="12"/>
                        <line x1="21" y1="12" x2="23" y2="12"/>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                </span>
            </button>
        </div>
    </nav>
</header>

<script>
    function applyTheme(theme: string) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        updateToggleIcon(theme);
    }

    function updateToggleIcon(theme: string) {
        const iconDark  = document.querySelector('.icon-dark') as HTMLElement | null;
        const iconLight = document.querySelector('.icon-light') as HTMLElement | null;
        if (!iconDark || !iconLight) return;
        if (theme === 'dark') {
            iconDark.style.display  = 'block';
            iconLight.style.display = 'none';
        } else {
            iconDark.style.display  = 'none';
            iconLight.style.display = 'block';
        }
    }

    function initTheme() {
        const saved = localStorage.getItem('theme') || 'light';
        applyTheme(saved);
    }

    document.addEventListener('DOMContentLoaded', () => {
        initTheme();
        const btn = document.getElementById('theme-toggle');
        btn?.addEventListener('click', () => {
            const current = document.documentElement.getAttribute('data-theme') || 'light';
            applyTheme(current === 'light' ? 'dark' : 'light');
        });
    });
</script>

<style>
    header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--header-bg);
        color: var(--header-text);
        border-bottom: 1px solid var(--header-border);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    }

    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5em;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 1.5em;
        height: 60px;
    }

    /* ── Brand ─────────────────────────────── */
    .site-brand { flex-shrink: 0; }

    .brand-link {
        display: flex;
        align-items: center;
        gap: 0.5em;
        text-decoration: none;
        color: var(--header-text);
        font-weight: 700;
        font-size: 1.05em;
        transition: color 0.2s;
    }
    .brand-link:hover { color: var(--color-strong); }

    .brand-icon {
        font-size: 1.3em;
        color: var(--color-strong);
        line-height: 1;
    }

    .brand-name {
        letter-spacing: 0.01em;
    }

    /* ── Nav links ─────────────────────────── */
    .nav-links {
        display: flex;
        align-items: center;
        gap: 0.25em;
    }

    .nav-links :global(a) {
        padding: 0.4em 0.75em;
        color: var(--header-text);
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.95em;
        transition: background 0.2s, color 0.2s;
        border-bottom: none;
    }
    .nav-links :global(a:hover) {
        background: rgba(242, 149, 89, 0.12);
        color: var(--color-strong);
    }
    .nav-links :global(a.active) {
        color: var(--color-strong);
        background: rgba(242, 149, 89, 0.1);
        font-weight: 600;
    }

    /* ── Right cluster ─────────────────────── */
    .right-cluster {
        display: flex;
        align-items: center;
        gap: 0.75em;
        flex-shrink: 0;
    }

    .social-links {
        display: flex;
        align-items: center;
        gap: 0.5em;
    }

    .social-links a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        color: var(--header-text);
        opacity: 0.85;
        text-decoration: none;
        transition: opacity 0.2s, color 0.2s, background 0.2s;
    }
    .social-links a:hover {
        opacity: 1;
        color: var(--color-strong);
        background: rgba(242, 149, 89, 0.1);
    }

    /* ── Theme toggle ──────────────────────── */
    .theme-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid var(--header-border);
        background: transparent;
        color: var(--header-text);
        cursor: pointer;
        opacity: 0.7;
        transition: opacity 0.2s, color 0.2s, background 0.2s, border-color 0.2s;
    }
    .theme-toggle:hover {
        opacity: 1;
        color: var(--color-strong);
        border-color: var(--color-strong);
        background: rgba(242, 149, 89, 0.08);
    }

    .icon-light { display: block; }
    .icon-dark  { display: none; }

    /* ── Mobile ────────────────────────────── */
    @media (max-width: 600px) {
        .social-links {
            display: none;
        }
        nav {
            padding: 0 1em;
        }
        .brand-name {
            font-size: 0.95em;
        }
    }
</style>
